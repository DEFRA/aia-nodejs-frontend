{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block pageTitle %}{{ pageTitle }}{% endblock %}

{% block content %}

<div id="errorSummary" class="govuk-error-summary" aria-labelledby="error-summary-title" role="alert" tabindex="-1" {% if not uploadError %}hidden style="display:none"{% endif %}>
  <h2 class="govuk-error-summary__title" id="error-summary-title">There is a problem</h2>
  <div class="govuk-error-summary__body">
    <ul class="govuk-list govuk-error-summary__list" id="errorSummaryList">
      {% if uploadError %}
        <li><a href="#file">{{ uploadError }}</a></li>
      {% endif %}
    </ul>
  </div>
</div>

<h1 class="govuk-heading-m">Upload the document to generate AI-powered insights</h1>

<form id="uploadForm" method="post" action="/upload" enctype="multipart/form-data" novalidate>
  <div class="govuk-form-group" id="templateTypeGroup">
    <label class="govuk-label" for="templateType">
      Document Template Type
    </label>
    <p class="govuk-error-message app-error-message" id="templateTypeError" hidden>
      <span class="govuk-visually-hidden">Error:</span>
      <span id="templateTypeErrorText"></span>
    </p>
    <select class="govuk-select" id="templateType" name="templateType" aria-describedby="templateTypeError">
      <option value="">Select Template Type</option>
      <option value="SDA" {% if templateType == 'SDA' %}selected{% endif %}>SDA</option>
    </select>
  </div>
  <div class="govuk-form-group" id="fileGroup">
    <label class="govuk-label" for="file">Select DOCX file</label>
    <p class="govuk-error-message app-error-message" id="fileError" hidden>
      <span class="govuk-visually-hidden">Error:</span>
      <span id="fileErrorText"></span>
    </p>
    <div class="file-selection-area">
      <input class="govuk-file-upload" id="file" name="file" type="file"
        accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
        aria-describedby="fileError"
        data-max-file-size-bytes="{{ maxUploadFileSizeBytes }}">
      <div id="fileSpinner" class="spinner"></div>
    </div>
  </div>
  {{ govukButton({ text: "Upload", attributes: { type: "submit", id: "submitButton" } }) }}
</form>


{% if uploads and uploads.length %}
<div class="govuk-form-group upload-history-container">
  <div class="upload-history-header">
    <h2 class="govuk-heading-m">Upload History</h2>
  </div>
  
<table class="govuk-table">
    <thead class="govuk-table__head">
      <tr class="govuk-table__row">
        <th class="govuk-table__header">Filename</th>
        <th class="govuk-table__header">Template Type</th>
        <th class="govuk-table__header">Status</th>
        <th class="govuk-table__header">Timestamp</th>
        <th class="govuk-table__header">Action</th>
      </tr>
    </thead>
    <tbody class="govuk-table__body">
      {% for upload in uploads %}
      <tr class="govuk-table__row">
        <td class="govuk-table__cell">{{ upload.originalFilename }}</td>
        <td class="govuk-table__cell">{{ upload.templateType }}</td>
        <td class="govuk-table__cell"><span class="status-badge status-{{ upload.status | lower }}">{{ upload.status }}</span></td>
        <td class="govuk-table__cell">{{ upload.createdAt }}</td>
        <td class="govuk-table__cell">
          {% if upload.status == 'Completed' %}
            <a href="/result?documentId={{ upload.documentId }}" class="govuk-link">View Results</a>
          {% elif upload.status == 'Error' %}
          {% else %}
            <span class="govuk-hint">Processing...</span>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  

  {# Pagination row with summary and navigation #}
    {% if pagination.summary or pagination.items or pagination.previous or pagination.next %}
    <div class="app-pagination-row app-pagination-row--{{ paginationAlignment | default('left') }} govuk-!-margin-top-6">

      {# GOV.UK Pagination #}
      {% if pagination.items or pagination.previous or pagination.next %}
      <div class="app-pagination-row__nav">
        {{ govukPagination({
          items: pagination.items,
          previous: pagination.previous,
          next: pagination.next,
          landmarkLabel: 'Pagination'
        }) }}
      </div>
      {% endif %}

      {# Pagination summary #}
      {% if pagination.summary %}
      <p class="govuk-body app-pagination-row__summary" data-testid="pagination-summary">Showing <strong>{{ pagination.summary.startItem }}</strong> to <strong>{{ pagination.summary.endItem }}</strong> of <strong>{{ pagination.summary.totalItems }}</strong> documents</p>
      {% endif %}

    </div>
    {% endif %}

</div>
{% endif %}


{% endblock %}
